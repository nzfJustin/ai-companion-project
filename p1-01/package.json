{
  "name": "ai-companion-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":              "tsx watch src/index.ts",
    "build":            "tsc --project tsconfig.build.json",
    "start":            "node dist/index.js",

    "db:generate":      "drizzle-kit generate",
    "db:migrate":       "tsx src/db/migrate.ts",
    "db:push":          "drizzle-kit push",
    "db:studio":        "drizzle-kit studio",
    "db:setup":         "psql $DATABASE_URL -f src/db/migrations/0000_enable_pgvector.sql && npm run db:migrate",

    "test":             "jest --runInBand",
    "test:watch":       "jest --runInBand --watch",
    "test:coverage":    "jest --runInBand --coverage",
    "test:integration": "docker compose -f docker-compose.test.yml up -d --wait && jest --runInBand --testPathPattern=integration && docker compose -f docker-compose.test.yml down",

    "lint":             "eslint src --ext .ts",
    "lint:fix":         "eslint src --ext .ts --fix",
    "typecheck":        "tsc --noEmit",
    "ci":               "npm run lint && npm run typecheck && npm run test"
  },
  "dependencies": {
    "dotenv":       "^16.4.5",
    "drizzle-orm":  "^0.30.10",
    "pg":           "^8.11.5"
  },
  "devDependencies": {
    "@types/jest":                     "^29.5.12",
    "@types/node":                     "^20.12.7",
    "@types/pg":                       "^8.11.5",
    "@typescript-eslint/eslint-plugin":"^7.7.1",
    "@typescript-eslint/parser":       "^7.7.1",
    "drizzle-kit":                     "^0.21.4",
    "eslint":                          "^8.57.0",
    "jest":                            "^29.7.0",
    "ts-jest":                         "^29.1.2",
    "tsx":                             "^4.8.2",
    "typescript":                      "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"],
    "moduleFileExtensions": ["ts", "js"],
    "collectCoverageFrom": ["src/**/*.ts", "!src/**/*.d.ts"]
  }
}
