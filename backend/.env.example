# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/companion

# Test DB (docker-compose.test.yml — port 5433)
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/companion_test

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
TEST_REDIS_URL=redis://localhost:6380

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_PRIVATE_KEY=CHANGE_ME_generate_a_real_key
JWT_PUBLIC_KEY=CHANGE_ME_generate_a_real_key
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# ─── Encryption ───────────────────────────────────────────────────────────────
# Min 32 chars. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=CHANGE_ME_min_32_chars_random_string

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Must be an exact origin, never "*" — every frontend request is sent with
# credentials: 'include' (it carries the httpOnly refresh_token cookie),
# and browsers reject a wildcard Access-Control-Allow-Origin on credentialed
# requests. Defaults to http://localhost:5173 (the frontend's Vite dev
# server) if unset — override for staging/production.
CORS_ORIGIN=http://localhost:5173

# ─── Stripe (Phase 4 — leave blank for now) ───────────────────────────────────
STRIPE_MONTHLY_PRICE_ID=
STRIPE_ANNUAL_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
