{
  "name": "ai-companion-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":              "tsx watch src/index.ts",
    "build":            "tsc --project tsconfig.build.json",
    "start":            "node dist/index.js",

    "db:generate":      "drizzle-kit generate",
    "db:migrate":       "tsx src/db/migrate.ts",
    "db:push":          "drizzle-kit push",
    "db:studio":        "drizzle-kit studio",
    "db:setup":         "psql $DATABASE_URL -f src/db/migrations/0000_enable_pgvector.sql && npm run db:migrate",

    "test":             "jest --runInBand",
    "test:unit":        "jest --runInBand --testPathIgnorePatterns='integration'",
    "test:integration": "jest --runInBand --testPathPattern='integration'",
    "test:watch":       "jest --runInBand --watch",
    "test:coverage":    "jest --runInBand --testPathIgnorePatterns='integration' --coverage",

    "lint":             "eslint src --ext .ts",
    "lint:fix":         "eslint src --ext .ts --fix",
    "typecheck":        "tsc --noEmit",
    "ci":               "npm run lint && npm run typecheck && npm run test:unit"
  },
  "dependencies": {
    "cors":        "^2.8.5",
    "dotenv":      "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "express":     "^4.19.2",
    "helmet":      "^7.1.0",
    "ioredis":     "^5.3.2",
    "pg":          "^8.11.5",
    "zod":         "^3.23.4",
    "bcryptjs":    "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cookie-parser": "^1.4.6",
    "@anthropic-ai/sdk": "^0.30.0"
  },
  "devDependencies": {
    "@types/cors":                      "^2.8.17",
    "@types/express":                   "^4.17.21",
    "@types/jest":                      "^29.5.12",
    "@types/node":                      "^20.12.7",
    "@types/pg":                        "^8.11.5",
    "@types/supertest":                 "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser":        "^7.7.1",
    "drizzle-kit":                      "^0.21.4",
    "eslint":                           "^8.57.0",
    "jest":                             "^29.7.0",
    "supertest":                        "^7.0.0",
    "ts-jest":                          "^29.1.2",
    "tsx":                              "^4.8.2",
    "typescript":                       "^5.4.5",
    "@types/bcryptjs":                  "^2.4.6",
    "@types/jsonwebtoken":              "^9.0.6",
    "@types/cookie-parser":             "^1.4.7"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"],
    "moduleFileExtensions": ["ts", "js"],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ],
    "collectCoverage": false,
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/src/db/schema.ts",
      "<rootDir>/src/routes/v1/.*\\.router\\.ts$",
      "<rootDir>/src/routes/health.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
    }
  }
}
